# ─── DeepSeek (https://platform.deepseek.com) ─────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# ─── Kimi / Moonshot — China inland (https://platform.moonshot.cn) ─
# International: KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.5

# ─── MiniMax — China inland (https://platform.minimaxi.com) ───
# International: MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.5

# ─── Database (PostgreSQL) ──────────────────────────────────────
# Either a full connection string:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_project_cto
# Or individual variables (fallback when DATABASE_URL is unset):
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=ai_project_cto

# ─── API Server ─────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8100
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
